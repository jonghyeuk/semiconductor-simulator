{
  "name": "semiconductor-simulator",
  "version": "1.0.0",
  "description": "반도체 공정 교육용 시뮬레이터",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.8.0"
  },
  "devDependencies": {
    "react-scripts": "5.0.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "tailwindcss": "^3.3.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.31",
    "firebase-tools": "^12.0.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "build:tailwind": "tailwindcss build src/styles/tailwind.css -o src/styles/output.css",
    "predeploy": "npm run build",
    "deploy": "firebase deploy",
    "deploy:hosting": "firebase deploy --only hosting"
  },
  "eslintConfig": {
